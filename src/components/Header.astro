---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2>
			<a href="/">HeathBarSec</a>
		</h2>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<div class="social-links">
			<a
				href="https://linkedin.com/in/austin-heath"
				target="_blank"
				rel="noopener noreferrer"
			>
				LinkedIn
			</a>

			<a
				href="https://github.com/hisokaxkillua"
				target="_blank"
				rel="noopener noreferrer"
			>
				GitHub
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5rem;
		background: rgba(15, 23, 42, 0.92);
		border-bottom: 1px solid var(--border);
		backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}

	h2 {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
	}

	h2 a {
		color: var(--text-bright);
		text-decoration: none;
	}

	.internal-links,
	.social-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	nav a {
		color: var(--text-muted);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	nav a:hover {
		color: var(--primary);
	}

	nav a.active {
		color: var(--text-bright);
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}

		nav {
			flex-wrap: wrap;
			justify-content: center;
			height: auto;
			padding: 1rem 0;
			gap: 0.75rem;
		}
	}
</style>